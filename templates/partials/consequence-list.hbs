{{!--
  Partial: consequence-list.hbs
  Renders the list of active consequence items on an actor.

  Severity levels (QuestWorlds SRD):
    1 = Hurt / Impaired   (–3)
    2 = Injured           (–6)
    3 = Dying / Broken    (–9)
    4 = Dead / Destroyed  (removed from play)

  Expected context:
    consequences — array of Item documents of type "consequence"
    owner        — boolean
--}}
<section class="consequences-section">
  <div class="section-header flexrow">
    <h3 class="section-title">
      <i class="fas fa-skull"></i>
      {{localize "QUESTWORLDS.Consequences.Title"}}
    </h3>
    {{#if owner}}
      <a class="item-create consequence-add"
         data-type="consequence"
         title="{{localize 'QUESTWORLDS.Consequences.Add'}}">
        <i class="fas fa-plus"></i>
      </a>
    {{/if}}
  </div>

  {{#if consequences.length}}
    <ul class="consequence-list items-list">
      {{#each consequences as |con|}}
        <li class="consequence-item item flexrow
                   consequence-severity-{{con.system.severity}}
                   {{#if con.system.recovering}}consequence--recovering{{/if}}"
            data-item-id="{{con.id}}">

          {{!-- Severity icon --}}
          <span class="consequence-severity-icon"
                title="{{localize 'QUESTWORLDS.Consequence.Severity'}} {{con.system.severity}}">
            {{#if (eq con.system.severity 1)}}<i class="fas fa-minus-circle"></i>{{/if}}
            {{#if (eq con.system.severity 2)}}<i class="fas fa-exclamation-circle"></i>{{/if}}
            {{#if (eq con.system.severity 3)}}<i class="fas fa-skull-crossbones"></i>{{/if}}
            {{#if (eq con.system.severity 4)}}<i class="fas fa-times-circle"></i>{{/if}}
          </span>

          {{!-- Name --}}
          <span class="consequence-name item-name">{{con.name}}</span>

          {{!-- Penalty badge (hidden for severity 4 — narrative removal) --}}
          {{#unless (eq con.system.severity 4)}}
            <span class="consequence-penalty tag tag--penalty"
                  title="{{localize 'QUESTWORLDS.Consequence.Penalty'}}">
              {{con.system.penalty}}
            </span>
          {{/unless}}

          {{!-- Source (contest / event that caused this) --}}
          {{#if con.system.source}}
            <span class="consequence-source">{{con.system.source}}</span>
          {{/if}}

          {{!-- Recovering indicator --}}
          {{#if con.system.recovering}}
            <span class="consequence-recovering tag tag--recovering"
                  title="{{localize 'QUESTWORLDS.Consequence.Recovering'}}">
              <i class="fas fa-heart"></i>
            </span>
          {{/if}}

          {{#if owner}}
            <div class="item-controls">
              {{!-- Toggle recovering --}}
              <a class="item-control consequence-toggle-recover"
                 data-item-id="{{con.id}}"
                 title="{{localize 'QUESTWORLDS.Consequence.ToggleRecover'}}">
                <i class="fas {{#if con.system.recovering}}fa-heart{{else}}fa-heart-broken{{/if}}"></i>
              </a>
              <a class="item-control item-edit"
                 data-item-id="{{con.id}}"
                 title="{{localize 'QUESTWORLDS.Edit'}}">
                <i class="fas fa-edit"></i>
              </a>
              <a class="item-control item-delete"
                 data-item-id="{{con.id}}"
                 title="{{localize 'QUESTWORLDS.Delete'}}">
                <i class="fas fa-trash"></i>
              </a>
            </div>
          {{/if}}
        </li>
      {{/each}}
    </ul>

    {{!-- Running penalty total (from actor.system.penaltyTotal) --}}
    <div class="consequence-total flexrow">
      <span class="consequence-total-label">{{localize "QUESTWORLDS.Consequences.TotalPenalty"}}</span>
      <span class="consequence-total-value tag tag--penalty">{{actor.system.penaltyTotal}}</span>
    </div>

  {{else}}
    <p class="empty-list">{{localize "QUESTWORLDS.Consequences.None"}}</p>
  {{/if}}
</section>
