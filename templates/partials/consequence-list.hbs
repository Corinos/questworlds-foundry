{{!--
  Partial: consequence-list.hbs
  Expected context: consequences, owner, actor
--}}
<section class="consequences-section">
  <div class="section-header flexrow">
    <h3 class="section-title">
      <i class="fas fa-skull"></i>
      {{localize "QUESTWORLDS.Consequences"}}
    </h3>
    {{#if owner}}
      <a data-action="itemCreate" data-type="consequence" title="Add Consequence">
        <i class="fas fa-plus"></i>
      </a>
    {{/if}}
  </div>

  {{#if consequences.length}}
    <ul class="consequence-list items-list">
      {{#each consequences as |con|}}
        <li class="consequence-item item flexrow consequence-severity-{{con.system.severity}} {{#if con.system.recovering}}consequence--recovering{{/if}}"
            data-item-id="{{con.id}}">

          <span class="consequence-severity-icon">
            {{#if (eq con.system.severity 1)}}<i class="fas fa-minus-circle"></i>{{/if}}
            {{#if (eq con.system.severity 2)}}<i class="fas fa-exclamation-circle"></i>{{/if}}
            {{#if (eq con.system.severity 3)}}<i class="fas fa-skull-crossbones"></i>{{/if}}
            {{#if (eq con.system.severity 4)}}<i class="fas fa-times-circle"></i>{{/if}}
          </span>

          <span class="consequence-name item-name">{{con.name}}</span>

          {{#unless (eq con.system.severity 4)}}
            <span class="consequence-penalty tag tag--penalty">{{con.system.penalty}}</span>
          {{/unless}}

          {{#if con.system.source}}
            <span class="consequence-source">{{con.system.source}}</span>
          {{/if}}

          {{#if con.system.recovering}}
            <span class="consequence-recovering tag tag--recovering">
              <i class="fas fa-heart"></i>
            </span>
          {{/if}}

          {{#if owner}}
            <div class="item-controls">
              <a data-action="itemEdit" data-item-id="{{con.id}}" title="{{localize 'QUESTWORLDS.Edit'}}">
                <i class="fas fa-edit"></i>
              </a>
              <a data-action="itemDelete" data-item-id="{{con.id}}" title="{{localize 'QUESTWORLDS.Delete'}}">
                <i class="fas fa-trash"></i>
              </a>
            </div>
          {{/if}}
        </li>
      {{/each}}
    </ul>

    <div class="consequence-total flexrow">
      <span class="consequence-total-label">{{localize "QUESTWORLDS.PenaltyTotal"}}</span>
      <span class="consequence-total-value tag tag--penalty">{{actor.system.penaltyTotal}}</span>
    </div>

  {{else}}
    <p class="empty-list">{{localize "QUESTWORLDS.EmptyConsequences"}}</p>
  {{/if}}
</section>
