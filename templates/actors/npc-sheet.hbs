{{!-- QuestWorlds NPC Sheet --}}
<form class="questworlds npc sheet" autocomplete="off">
  <header class="sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
    <div class="header-fields">
      <h1 class="charname">
        <input name="name" type="text" value="{{actor.name}}" placeholder="NPC Name" />
      </h1>
      <div class="header-details flexrow">
        <div class="form-group">
          <label>{{localize "QUESTWORLDS.NpcType"}}</label>
          <select name="system.npcType">
            <option value="independent" {{#if (qwEq system.npcType "independent")}}selected{{/if}}>Independent</option>
            <option value="master"      {{#if (qwEq system.npcType "master")}}selected{{/if}}>Master</option>
            <option value="minion"      {{#if (qwEq system.npcType "minion")}}selected{{/if}}>Minion</option>
          </select>
        </div>
        <div class="form-group">
          <label>{{localize "QUESTWORLDS.ResistanceRating"}}</label>
          <input type="number" name="system.resistanceRating" value="{{system.resistanceRating}}" min="1" />
          <span class="resistance-notation">{{qwRating system.resistanceRating}}</span>
          <input type="text" name="system.resistanceLabel" value="{{system.resistanceLabel}}" placeholder="Moderate" />
        </div>
      </div>
    </div>
  </header>

  <section class="sheet-body npc-body">
    <nav class="sheet-tabs tabs" data-group="primary">
      <a class="item {{#if (eq tabs.abilities.id tabGroups.primary)}}active{{/if}}" data-tab="abilities" data-group="primary">{{localize "QUESTWORLDS.TabAbilities"}}</a>
      <a class="item {{#if (eq tabs.notes.id tabGroups.primary)}}active{{/if}}" data-tab="notes" data-group="primary">{{localize "QUESTWORLDS.TabNotes"}}</a>
    </nav>

    <div class="tab abilities {{tabs.abilities.cssClass}}" data-group="primary" data-tab="abilities">
      <div class="abilities-toolbar flexrow">
        <h3>{{localize "QUESTWORLDS.Abilities"}}</h3>
        <a data-action="itemCreate" data-type="ability" title="{{localize 'QUESTWORLDS.AddAbility'}}"><i class="fas fa-plus"></i></a>
      </div>

      <div class="abilities-list" data-sort-container="keywords">
        {{#if grouped.keywords.length}}
          {{#each grouped.keywords as |group|}}
            <div class="ability-row keyword flexrow" data-item-id="{{group.item.id}}" draggable="true">
              <span class="ability-icon"><i class="fas fa-key"></i></span>
              <span class="ability-name">
                <input class="inline-name" data-item-id="{{group.item.id}}" data-field="name" value="{{group.item.name}}" />
                <a data-action="abilityRoll" data-item-id="{{group.item.id}}" title="{{localize "QUESTWORLDS.RollAbility"}}"><i class="fas fa-dice"></i></a>
              </span>
              <input
                class="inline-rating"
                type="number" min="1" max="100" step="1"
                data-item-id="{{group.item.id}}"
                data-field="system.rating"
                value="{{group.item.system.rating}}"
              />
              <div class="item-controls flexrow">
                <a data-action="itemEdit" data-item-id="{{group.item.id}}" title="{{localize "QUESTWORLDS.Edit"}}"><i class="fas fa-edit"></i></a>
                <a data-action="itemDelete" data-item-id="{{group.item.id}}" title="{{localize "QUESTWORLDS.Delete"}}"><i class="fas fa-trash"></i></a>
              </div>
            </div>

            {{#if group.breakouts.length}}
              <div class="breakouts-list" data-sort-container="breakouts">
                {{#each group.breakouts as |breakout|}}
                  <div class="ability-row breakout flexrow" data-item-id="{{breakout.id}}" draggable="true">
                    <span class="ability-icon"><i class="fas fa-code-branch"></i></span>
                    <span class="ability-name breakout-name">
                      ↳ <input class="inline-name" data-item-id="{{breakout.id}}" data-field="name" value="{{breakout.name}}" />
                      <a data-action="abilityRoll" data-item-id="{{breakout.id}}" title="{{localize "QUESTWORLDS.RollAbility"}}"><i class="fas fa-dice"></i></a>
                    </span>
                    <input
                      class="inline-rating"
                      type="number" min="1" max="100" step="1"
                      data-item-id="{{breakout.id}}"
                      data-field="effectiveRating"
                      value="{{breakout.effectiveRating}}"
                    />
                    <div class="item-controls flexrow">
                      <a data-action="itemEdit" data-item-id="{{breakout.id}}" title="{{localize "QUESTWORLDS.Edit"}}"><i class="fas fa-edit"></i></a>
                      <a data-action="itemDelete" data-item-id="{{breakout.id}}" title="{{localize "QUESTWORLDS.Delete"}}"><i class="fas fa-trash"></i></a>
                    </div>
                  </div>
                {{/each}}
              </div>
            {{/if}}

            <div class="breakout-add">
              <a data-action="itemCreate" data-type="ability" data-ability-type="breakout" data-keyword-id="{{group.item.id}}">
                <i class="fas fa-plus"></i> {{localize "QUESTWORLDS.AddBreakout"}}
              </a>
            </div>
          {{/each}}
        {{else}}
          <div class="empty-state">
            <i class="fas fa-seedling"></i>
            <span>{{localize "QUESTWORLDS.EmptyKeywords"}}</span>
          </div>
        {{/if}}
      </div>

      <div class="standalone-list" data-sort-container="standalone">
        {{#if grouped.standalone.length}}
          {{#each grouped.standalone as |ability|}}
            <div class="ability-row standalone flexrow" data-item-id="{{ability.id}}" draggable="true">
              <span class="ability-icon"><i class="fas fa-shield-alt"></i></span>
              <span class="ability-name">
                <input class="inline-name" data-item-id="{{ability.id}}" data-field="name" value="{{ability.name}}" />
                <a data-action="abilityRoll" data-item-id="{{ability.id}}" title="{{localize "QUESTWORLDS.RollAbility"}}"><i class="fas fa-dice"></i></a>
              </span>
              <input
                class="inline-rating"
                type="number" min="1" max="100" step="1"
                data-item-id="{{ability.id}}"
                data-field="system.rating"
                value="{{ability.system.rating}}"
              />
              <div class="item-controls flexrow">
                <a data-action="itemEdit" data-item-id="{{ability.id}}" title="{{localize "QUESTWORLDS.Edit"}}"><i class="fas fa-edit"></i></a>
                <a data-action="itemDelete" data-item-id="{{ability.id}}" title="{{localize "QUESTWORLDS.Delete"}}"><i class="fas fa-trash"></i></a>
              </div>
            </div>
          {{/each}}
        {{else}}
          <div class="empty-state">
            <i class="fas fa-seedling"></i>
            <span>{{localize "QUESTWORLDS.EmptyStandalones"}}</span>
          </div>
        {{/if}}
      </div>
    </div>

    <div class="tab notes {{tabs.notes.cssClass}}" data-group="primary" data-tab="notes">
      <div class="npc-notes">
        {{editor system.notes target="system.notes" button=true editable=isOwner}}
      </div>
    </div>
  </section>
</form>
