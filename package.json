{
  "private": true,
  "name": "questworlds",
  "version": "0.1.0",
  "type": "module",
  "description": "Foundry VTT system for QuestWorlds",
  "main": "module/questworlds.mjs",
  "scripts": {
    "clean": "rimraf dist node_modules",
    "lint:scripts": "eslint \"**/*.{js,mjs,ts,tsx}\"",
    "lint:fix": "npm run lint:scripts -- --fix",
    "format": "prettier --write .",
    "typecheck": "tsc -noEmit",
    "build": "vite build",
    "dev": "vite",
    "test": "vitest"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.3",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-static-copy": "^3.2.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "changeset": "^0.2.6"
  }
}
